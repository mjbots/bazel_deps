Rename Python's static sinpi() helper. glibc 2.41 added a public sinpi()
declaration to <math.h>, which collides with this static definition.

--- Modules/mathmodule.c
+++ Modules/mathmodule.c
@@ -67,7 +67,7 @@
 static const double logpi = 1.144729885849400174143427351353058711647;

 static double
-sinpi(double x)
+_py_sinpi(double x)
 {
     double y, r;
     int n;
@@ -296,7 +296,7 @@
        integer. */
     if (absx > 200.0) {
         if (x < 0.0) {
-            return 0.0/sinpi(x);
+            return 0.0/_py_sinpi(x);
         }
         else {
             errno = ERANGE;
@@ -320,7 +320,7 @@
     }
     z = z * lanczos_g / y;
     if (x < 0.0) {
-        r = -pi / sinpi(absx) / absx * exp(y) / lanczos_sum(absx);
+        r = -pi / _py_sinpi(absx) / absx * exp(y) / lanczos_sum(absx);
         r -= z * r;
         if (absx < 140.0) {
             r /= pow(y, absx - 0.5);
@@ -390,7 +390,7 @@
     r += (absx - 0.5) * (log(absx + lanczos_g - 0.5) - 1);
     if (x < 0.0)
         /* Use reflection formula to get value for negative x. */
-        r = logpi - log(fabs(sinpi(absx))) - log(absx) - r;
+        r = logpi - log(fabs(_py_sinpi(absx))) - log(absx) - r;
     if (Py_IS_INFINITY(r))
         errno = ERANGE;
     return r;
